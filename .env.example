# Convex
EXPO_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# Add your Convex deployment URL here
# Get it by running: npx convex dev

# Paddle Billing (server-side only — set in Convex Dashboard → Settings → Environment Variables)
# API key from Paddle Developer Tools → Authentication (sandbox key contains sdbx_, live contains live_)
PADDLE_API_KEY=pdl_sdbx_apikey_...

# Webhook signing secret from the notification destination (endpoint secret key), NOT the API key
# https://developer.paddle.com/webhooks/signature-verification
PADDLE_WEBHOOK_SECRET=

# Recurring catalog price IDs (pri_...) for each paid tier — create products/prices in Paddle dashboard
PADDLE_PRICE_STARTER=
PADDLE_PRICE_PROFESSIONAL=
PADDLE_PRICE_ENTERPRISE=

# ISO 3166-1 alpha-2 country code for the prefilled billing address before checkout (e.g. HN, US)
PADDLE_CHECKOUT_DEFAULT_COUNTRY_CODE=HN

# Convex HTTP webhook URL (configure in Paddle → Developer Tools → Notifications → notification destination):
# https://<deployment>.convex.site/paddle-webhook
